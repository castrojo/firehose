{
  "name": "firehose",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [4321, 8080],
  "portsAttributes": {
    "4321": {
      "label": "Astro Dev Server",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Container (nginx)",
      "onAutoForward": "silent"
    }
  },
  "containerEnv": {
    "GOPATH": "/root/go"
  },
  "postCreateCommand": "npm ci && cd firehose-go && go mod download",
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "golang.go",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.autoUpdate": false
      }
    }
  }
}

