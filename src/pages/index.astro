---
import ReleaseCard from '../components/ReleaseCard.astro';
import CollapsibleReleaseGroup from '../components/CollapsibleReleaseGroup.astro';
import InfiniteScroll from '../components/InfiniteScroll.astro';
import ErrorBanner from '../components/ErrorBanner.astro';
import FilterBar from '../components/FilterBar.astro';
import InfoBox from '../components/InfoBox.astro';
import KubeConBanner from '../components/KubeConBanner.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { groupReleases } from '../lib/releaseGrouping';
import { getActiveBanner } from '../lib/banners';

// Import releases from JSON (generated by Go pipeline)
import releasesData from '../data/releases.json';

// Base URL from Astro config (e.g., /firehose for GitHub Pages)
const baseUrl = (import.meta.env.BASE_URL as string).replace(/\/*$/, '/');

// Get active KubeCon banner from CNCF
const activeBanner = await getActiveBanner();

// Transform JSON releases to match Astro content collection format
// Go pipeline already sorted by pubDate descending
const releases = (releasesData.releases as any[]).map((r: any) => ({
  id: r.id,
  collection: 'releases' as const, // Required for compatibility with groupReleases()
  data: {
    title: r.title,
    link: r.link,
    pubDate: r.pubDate,
    isoDate: r.pubDate, // Go outputs RFC3339, same as isoDate
    content: r.content || '',
    contentSnippet: r.content ? r.content.substring(0, 200) : '', // Generate snippet from content
    guid: r.guid || r.id,
    projectName: r.projectName || '',
    projectDescription: r.projectDescription || '',
    projectStatus: r.projectStatus,
    projectHomepage: r.projectHomepage || '',
    feedUrl: r.feedUrl,
    feedTitle: r.feedTitle || '',
    feedStatus: r.feedStatus,
    feedError: undefined, // Go doesn't include errors in successful releases
    feedErrorType: undefined,
    fetchedAt: r.fetchedAt,
  }
})) as any[];

// Filter out error entries (feedStatus === 'error')
const validReleases = releases.filter(r => r.data.feedStatus !== 'error');

// Count errors from metadata (Go provides accurate counts)
const errorCount = releasesData.metadata.stats.feedsFailed;

// Sort by date (newest first)
const sortedReleases = validReleases.sort((a, b) => {
  const dateA = a.data.isoDate ? new Date(a.data.isoDate).getTime() : 0;
  const dateB = b.data.isoDate ? new Date(b.data.isoDate).getTime() : 0;
  return dateB - dateA;
});

// Get error entries for error banner (currently no errors in this run)
const errorEntries = (releasesData.feeds as any[])
  .filter((f: any) => f.status === 'error')
  .map((f: any) => ({
    projectName: f.feedUrl.split('/').slice(3, 5).join('/'), // Extract org/repo from URL
    feedUrl: f.feedUrl,
    feedError: f.error || 'Unknown error', // Placeholder for future error handling
    feedErrorType: f.errorType,
  }));

// Count by project status
const graduatedCount = new Set(validReleases.filter(r => r.data.projectStatus === 'graduated').map(r => r.data.projectName)).size;
const incubatingCount = new Set(validReleases.filter(r => r.data.projectStatus === 'incubating').map(r => r.data.projectName)).size;
const sandboxCount = new Set(validReleases.filter(r => r.data.projectStatus === 'sandbox').map(r => r.data.projectName)).size;

// Calculate additional metrics
const totalProjects = new Set(validReleases.map(r => r.data.projectName)).size;
const last30Days = sortedReleases.filter(r => {
  const releaseDate = r.data.isoDate ? new Date(r.data.isoDate) : null;
  if (!releaseDate) return false;
  const thirtyDaysAgo = new Date();
  thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
  return releaseDate >= thirtyDaysAgo;
}).length;

// Group releases for collapsible display
const releaseGroups = groupReleases(sortedReleases);

// Pagination: Initial batch for server-side render
const INITIAL_BATCH = 30;
const initialGroups = releaseGroups.slice(0, INITIAL_BATCH);
const remainingGroups = releaseGroups.slice(INITIAL_BATCH);

// For backward compatibility: flatten groups back to releases for filters/search
const initialReleases = initialGroups.flatMap(g => [g.leadRelease, ...g.collapsedReleases]);
const remainingReleases = remainingGroups.flatMap(g => [g.leadRelease, ...g.collapsedReleases]);

// Extract unique project names (sorted alphabetically)
const uniqueProjects = [...new Set(sortedReleases.map(r => r.data.projectName || r.data.feedTitle).filter(p => p !== undefined))] as string[];
uniqueProjects.sort();

// Extract unique statuses (graduated, incubating)
const uniqueStatuses = [...new Set(sortedReleases.map(r => r.data.projectStatus).filter(s => s !== undefined))] as string[];
uniqueStatuses.sort();

// Serialize remaining releases for client-side hydration
// Note: Only pass minimal data (no full markdown content) to keep JSON small
const remainingReleasesData = remainingReleases.map(r => ({
  id: r.id,
  data: {
    title: r.data.title,
    link: r.data.link,
    isoDate: r.data.isoDate,
    contentSnippet: r.data.contentSnippet,
    projectName: r.data.projectName,
    projectDescription: r.data.projectDescription,
    projectStatus: r.data.projectStatus,
    feedTitle: r.data.feedTitle,
  }
}));
---

<MainLayout
  activeSection="releases"
  pageTitle="CNCF Releases"
  feedUrl={`${baseUrl}feed.xml`}
  projects={uniqueProjects}
>
  <!-- Sidebar content -->
  <Fragment slot="sidebar">
    <!-- About CNCF box -->
    <InfoBox 
      title="About" 
      description="CNCF Releases aggregates release notes from CNCF projects."
      links={[
        { text: 'Subscribe', url: `${baseUrl}feed.xml`, external: false, rss: true },
        { text: 'CNCF Homepage', url: 'https://www.cncf.io/', external: true },
        { text: 'CNCF Landscape', url: 'https://landscape.cncf.io/', external: true },
        { text: 'GitHub Repository', url: 'https://github.com/castrojo/firehose', external: true }
      ]}
    />

    <!-- KubeCon Event Banner (if active) -->
    {activeBanner && (
      <KubeConBanner 
        name={activeBanner.name}
        link={activeBanner.link}
        lightImage={activeBanner.lightImage}
        darkImage={activeBanner.darkImage}
      />
    )}

    <!-- Stats box -->
    <div class="stats">
      <h2 class="sidebar-heading stats-heading">Statistics</h2>
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-value">{totalProjects}</div>
          <div class="stat-label">Total Projects</div>
        </div>
        <div class="stat">
          <div class="stat-value">{graduatedCount}</div>
          <div class="stat-label">Graduated</div>
        </div>
        <div class="stat">
          <div class="stat-value">{incubatingCount}</div>
          <div class="stat-label">Incubating</div>
        </div>
        <div class="stat">
          <div class="stat-value">{sandboxCount}</div>
          <div class="stat-label">Sandbox</div>
        </div>
        <div class="stat">
          <div class="stat-value">{sortedReleases.length}</div>
          <div class="stat-label">Total Releases</div>
        </div>
        <div class="stat">
          <div class="stat-value">{last30Days}</div>
          <div class="stat-label">Last 30 Days</div>
        </div>
      </div>
      {errorCount > 0 && (
        <div class="stat stat-error stat-full-width">
          <div class="stat-value">{errorCount}</div>
          <div class="stat-label">Failed Feeds</div>
        </div>
      )}
    </div>

    <!-- Filters in sidebar -->
    <div class="sidebar-section">
      <h2 class="sidebar-heading">Filters</h2>
      <FilterBar 
        projects={uniqueProjects}
        statuses={uniqueStatuses}
        totalCount={sortedReleases.length}
      />
    </div>

    <!-- Made with love box -->
    <div class="sidebar-section made-with-love">
      <p>Made with <strong>&lt;3</strong> by your CNCF Projects Team</p>
    </div>
  </Fragment>

  <!-- Main content -->
  <!-- Error banner (if any feeds failed) -->
  {errorCount > 0 && (
    <ErrorBanner errors={errorEntries} />
  )}

  <!-- Infinite scroll container with data hydration -->
  <div class="infinite-scroll-container" data-releases={JSON.stringify(remainingReleasesData)}>
    <InfiniteScroll>
      <!-- Initial batch rendered server-side with grouping -->
      {initialGroups.map((group, index) => (
        <CollapsibleReleaseGroup 
          group={group} 
          groupId={`group-${index}`}
        />
      ))}
    </InfiniteScroll>
  </div>

  <!-- Footer stats -->
  <Fragment slot="footer-stats">
    <p>Aggregating {sortedReleases.length} releases from {new Set(sortedReleases.map(r => r.data.projectName)).size} CNCF projects</p>
  </Fragment>
</MainLayout>

<script>
  // @ts-nocheck
  // Home link handler - clear filters and scroll to top
  document.getElementById('home-link')?.addEventListener('click', (e) => {
    e.preventDefault();
    
    // Clear all filters
    const projectSelect = document.getElementById('filter-project') as HTMLSelectElement;
    const statusSelect = document.getElementById('filter-status') as HTMLSelectElement;
    if (projectSelect) projectSelect.value = '';
    if (statusSelect) statusSelect.value = '';
    
    // Reset date range buttons
    document.querySelectorAll('.date-range-buttons button').forEach(btn => {
      btn.classList.remove('active');
    });
    const allButton = document.querySelector('[data-days="all"]');
    allButton?.classList.add('active');
    
    // Clear search
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    if (searchInput) {
      searchInput.value = '';
      // Trigger search clear event
      const clearButton = document.getElementById('search-clear');
      if (clearButton && clearButton.style.display !== 'none') {
        clearButton.click();
      }
    }
    
    // Trigger filter update by clicking clear filters button
    document.getElementById('clear-filters')?.click();
    
    // Scroll to top smoothly
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

<script>
  // @ts-nocheck
  // Keyboard navigation
  class KeyboardNavigator {
    focusedIndex = -1;
    /** @type {HTMLElement[]} */
    items = [];
    /** @type {HTMLElement | null} */
    searchInput = null;
    /** @type {string} */
    itemSelector = '';
    
    /**
     * @param {string} itemSelector
     * @param {string} searchInputSelector
     */
    constructor(itemSelector, searchInputSelector) {
      this.itemSelector = itemSelector;
      this.items = Array.from(document.querySelectorAll(itemSelector));
      this.searchInput = document.querySelector(searchInputSelector);
      this.attachListeners();
      console.log(`[KeyboardNav] Initialized with ${this.items.length} items`);
    }
    
    attachListeners() {
      document.addEventListener('keydown', (e) => {
        if (this.isTypingContext(e.target)) return;
        
        switch(e.key) {
          case 'j':
            e.preventDefault();
            this.moveDown();
            break;
          case 'k':
            e.preventDefault();
            this.moveUp();
            break;
          case '/':
            e.preventDefault();
            this.focusSearch();
            break;
          case 'o':
          case 'Enter':
            e.preventDefault();
            this.openFocused();
            break;
          case '?':
            e.preventDefault();
            this.showHelp();
            break;
          case 't':
            e.preventDefault();
            this.toggleTheme();
            break;
          case ' ':
            e.preventDefault();
            if (e.shiftKey) {
              window.scrollBy({ top: -window.innerHeight, behavior: 'smooth' });
            } else {
              window.scrollBy({ top: window.innerHeight, behavior: 'smooth' });
            }
            break;
          case 'h':
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
            break;
          case 's':
            e.preventDefault();
            this.focusSearch();
            break;
          case 'Escape':
            this.handleEscape();
            break;
        }
      });
    }
    
    /**
     * @param {EventTarget | null} target
     * @returns {boolean}
     */
    isTypingContext(target) {
      if (!target || !(target instanceof HTMLElement)) return false;
      const tagName = target.tagName.toLowerCase();
      if (tagName === 'input' || tagName === 'textarea') return true;
      if (target.isContentEditable) return true;
      if (target.closest('.pagefind-ui') || target.closest('.search-bar')) return true;
      return false;
    }
    
    moveDown() {
      if (this.items.length === 0) return;
      this.focusedIndex = Math.min(this.focusedIndex + 1, this.items.length - 1);
      this.scrollToFocused();
      this.announceNavigation();
    }
    
    moveUp() {
      if (this.items.length === 0) return;
      this.focusedIndex = Math.max(this.focusedIndex - 1, 0);
      this.scrollToFocused();
      this.announceNavigation();
    }
    
    scrollToFocused() {
      const item = this.items[this.focusedIndex];
      if (!item) return;
      this.items.forEach(el => el.classList.remove('kbd-focused'));
      item.classList.add('kbd-focused');
      item.scrollIntoView({ behavior: 'smooth', block: 'start', inline: 'nearest' });
    }
    
    openFocused() {
      const item = this.items[this.focusedIndex];
      if (!item) return;
      
      // Check if focused item is a collapse button
      if (item.classList.contains('collapse-button')) {
        item.click();
        return;
      }
      
      // Otherwise, open the release link
      const link = item.querySelector('a[href]');
      if (link) window.open(link.href, '_blank', 'noopener,noreferrer');
    }
    
    focusSearch() {
      if (this.searchInput) {
        this.searchInput.focus();
        this.searchInput.select();
      }
    }
    
    showHelp() {
      document.getElementById('keyboard-help-modal')?.classList.add('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
    }
    
    toggleTheme() {
      if (typeof window.toggleTheme === 'function') {
        window.toggleTheme();
      }
    }
    
    hideHelp() {
      document.getElementById('keyboard-help-modal')?.classList.remove('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.remove('visible');
    }
    
    handleEscape() {
      const helpModal = document.getElementById('keyboard-help-modal');
      if (helpModal?.classList.contains('visible')) {
        this.hideHelp();
        return;
      }
      if (document.activeElement === this.searchInput) {
        this.searchInput?.blur();
        return;
      }
      this.items.forEach(el => el.classList.remove('kbd-focused'));
      this.focusedIndex = -1;
    }
    
    announceNavigation() {
      const item = this.items[this.focusedIndex];
      const liveRegion = document.getElementById('kbd-live-region');
      if (liveRegion && item) {
        const title = item.querySelector('h2, .release-title')?.textContent?.trim() || 'Release';
        liveRegion.textContent = `Focused: ${title}`;
      }
    }
    
    refresh() {
      this.items = Array.from(document.querySelectorAll(this.itemSelector));
      console.log(`[KeyboardNav] Refreshed, now tracking ${this.items.length} items`);
    }
  }

  let navigator = null;
  document.addEventListener('DOMContentLoaded', () => {
    navigator = new KeyboardNavigator('.release-card:not([aria-hidden="true"] .release-card), .collapse-button', '#search-input, .search-bar input');
    
    // Refresh navigator when collapse state changes
    document.addEventListener('collapseStateChanged', () => navigator?.refresh());
    
    const observer = new MutationObserver(() => navigator?.refresh());
    const releaseList = document.getElementById('release-list');
    if (releaseList) observer.observe(releaseList, { childList: true });
    const infiniteScrollContainer = document.querySelector('.infinite-scroll-container');
    if (infiniteScrollContainer) observer.observe(infiniteScrollContainer, { childList: true, subtree: true });
  });
</script>
