---
import ReleaseCard from '../../components/ReleaseCard.astro';
import InfiniteScroll from '../../components/InfiniteScroll.astro';
import FilterBar from '../../components/FilterBar.astro';
import InfoBox from '../../components/InfoBox.astro';
import MainLayout from '../../layouts/MainLayout.astro';

// Import releases from JSON (generated by Go pipeline)
import releasesData from '../../data/releases.json';

// Base URL from Astro config — '/' for custom domain, '/subpath' for GitHub Pages subpath deploys
const baseUrl = (import.meta.env.BASE_URL as string).replace(/\/*$/, '/');

// Transform JSON news items to match ReleaseCard's expected format
const newsItems = ((releasesData as any).news as any[]).map((r: any) => ({
  id: r.id,
  collection: 'releases' as const,
  data: {
    title: r.title,
    link: r.link,
    pubDate: r.pubDate,
    isoDate: r.pubDate,
    content: r.content || '',
    contentSnippet: r.contentSnippet || (r.content ? r.content.substring(0, 200) : ''),
    guid: r.guid || r.id,
    projectName: r.projectName || '',
    projectDescription: r.projectDescription || '',
    projectStatus: r.projectStatus,
    projectHomepage: r.projectHomepage || '',
    feedUrl: r.feedUrl,
    feedTitle: r.feedTitle || '',
    feedStatus: r.feedStatus,
    feedError: undefined,
    feedErrorType: undefined,
    fetchedAt: r.fetchedAt,
  }
})) as any[];

// Filter out error entries
const validNews = newsItems.filter(r => r.data.feedStatus !== 'error');

// Sort by date (newest first)
const sortedNews = validNews.sort((a, b) => {
  const dateA = a.data.isoDate ? new Date(a.data.isoDate).getTime() : 0;
  const dateB = b.data.isoDate ? new Date(b.data.isoDate).getTime() : 0;
  return dateB - dateA;
});

// Count by project status
const graduatedCount = new Set(sortedNews.filter(r => r.data.projectStatus === 'graduated').map(r => r.data.projectName)).size;
const incubatingCount = new Set(sortedNews.filter(r => r.data.projectStatus === 'incubating').map(r => r.data.projectName)).size;
const sandboxCount = new Set(sortedNews.filter(r => r.data.projectStatus === 'sandbox').map(r => r.data.projectName)).size;
const totalProjects = new Set(sortedNews.map(r => r.data.projectName)).size;

const last30Days = sortedNews.filter(r => {
  const releaseDate = r.data.isoDate ? new Date(r.data.isoDate) : null;
  if (!releaseDate) return false;
  const thirtyDaysAgo = new Date();
  thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
  return releaseDate >= thirtyDaysAgo;
}).length;

// Pagination: Initial batch for server-side render
const INITIAL_BATCH = 30;
const initialNews = sortedNews.slice(0, INITIAL_BATCH);
const remainingNews = sortedNews.slice(INITIAL_BATCH);

// Extract unique project names (sorted alphabetically)
const uniqueProjects = [...new Set(sortedNews.map(r => r.data.projectName || r.data.feedTitle).filter(p => p !== undefined))] as string[];
uniqueProjects.sort();

// Extract unique statuses
const uniqueStatuses = [...new Set(sortedNews.map(r => r.data.projectStatus).filter(s => s !== undefined))] as string[];
uniqueStatuses.sort();

// Serialize remaining news for client-side hydration (minimal data)
const remainingNewsData = remainingNews.map(r => ({
  id: r.id,
  data: {
    title: r.data.title,
    link: r.data.link,
    isoDate: r.data.isoDate,
    contentSnippet: r.data.contentSnippet,
    projectName: r.data.projectName,
    projectDescription: r.data.projectDescription,
    projectStatus: r.data.projectStatus,
    feedTitle: r.data.feedTitle,
  }
}));
---

<MainLayout
  activeSection="news"
  pageTitle="CNCF News | The Firehose"
  feedUrl={`${baseUrl}news.xml`}
  projects={uniqueProjects}
>
  <!-- Sidebar content -->
  <Fragment slot="sidebar">
    <!-- About box -->
    <InfoBox
      title="About"
      description="CNCF News aggregates blog posts from CNCF projects."
      links={[
        { text: 'Subscribe', url: `${baseUrl}news.xml`, external: false, rss: true },
        { text: 'CNCF Homepage', url: 'https://www.cncf.io/', external: true },
        { text: 'CNCF Landscape', url: 'https://landscape.cncf.io/', external: true },
        { text: 'GitHub Repository', url: 'https://github.com/castrojo/firehose', external: true }
      ]}
    />

    <!-- Stats box -->
    <div class="stats">
      <h2 class="sidebar-heading stats-heading">Statistics</h2>
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-value">{totalProjects}</div>
          <div class="stat-label">Total Projects</div>
        </div>
        <div class="stat">
          <div class="stat-value">{graduatedCount}</div>
          <div class="stat-label">Graduated</div>
        </div>
        <div class="stat">
          <div class="stat-value">{incubatingCount}</div>
          <div class="stat-label">Incubating</div>
        </div>
        <div class="stat">
          <div class="stat-value">{sandboxCount}</div>
          <div class="stat-label">Sandbox</div>
        </div>
        <div class="stat">
          <div class="stat-value">{sortedNews.length}</div>
          <div class="stat-label">Total Posts</div>
        </div>
        <div class="stat">
          <div class="stat-value">{last30Days}</div>
          <div class="stat-label">Last 30 Days</div>
        </div>
      </div>
    </div>

    <!-- Filters in sidebar -->
    <div class="sidebar-section">
      <h2 class="sidebar-heading">Filters</h2>
      <FilterBar
        projects={uniqueProjects}
        statuses={uniqueStatuses}
        totalCount={sortedNews.length}
      />
    </div>

    <!-- Made with love -->
    <div class="sidebar-section made-with-love">
      <p>Made with <strong>&lt;3</strong> by your CNCF Projects Team</p>
    </div>
  </Fragment>

  <!-- Main content -->
  <div class="infinite-scroll-container" data-releases={JSON.stringify(remainingNewsData)}>
    <InfiniteScroll>
      {initialNews.map(item => (
        <ReleaseCard release={item} />
      ))}
    </InfiniteScroll>
  </div>

  <!-- Footer stats -->
  <Fragment slot="footer-stats">
    <p>Aggregating {sortedNews.length} blog posts from {totalProjects} CNCF projects</p>
  </Fragment>
</MainLayout>

<script>
  // @ts-nocheck
  // Keyboard navigation (same as releases page)
  class KeyboardNavigator {
    focusedIndex = -1;
    /** @type {HTMLElement[]} */
    items = [];
    /** @type {HTMLElement | null} */
    searchInput = null;
    /** @type {string} */
    itemSelector = '';

    /**
     * @param {string} itemSelector
     * @param {string} searchInputSelector
     */
    constructor(itemSelector, searchInputSelector) {
      this.itemSelector = itemSelector;
      this.items = Array.from(document.querySelectorAll(itemSelector));
      this.searchInput = document.querySelector(searchInputSelector);
      this.attachListeners();
    }

    attachListeners() {
      document.addEventListener('keydown', (e) => {
        if (this.isTypingContext(e.target)) return;

        switch(e.key) {
          case 'j':
            e.preventDefault();
            this.moveFocus(1);
            break;
          case 'k':
            e.preventDefault();
            this.moveFocus(-1);
            break;
          case 'o':
          case 'Enter':
            e.preventDefault();
            this.openFocused();
            break;
          case '/':
            e.preventDefault();
            this.searchInput?.focus();
            break;
          case '?':
            e.preventDefault();
            this.showHelp();
            break;
          case 't':
            e.preventDefault();
            this.toggleTheme();
            break;
          case 'Escape':
            e.preventDefault();
            this.handleEscape();
            break;
        }
      });
    }

    isTypingContext(target) {
      if (!target) return false;
      const tag = target.tagName?.toLowerCase();
      return tag === 'input' || tag === 'textarea' || tag === 'select' || target.isContentEditable;
    }

    moveFocus(direction) {
      const visibleItems = Array.from(document.querySelectorAll(this.itemSelector))
        .filter(el => !el.closest('[aria-hidden="true"]'));
      this.items = visibleItems;

      if (this.items.length === 0) return;

      this.items.forEach(el => el.classList.remove('kbd-focused'));

      this.focusedIndex = Math.max(0, Math.min(this.items.length - 1, this.focusedIndex + direction));
      const focused = this.items[this.focusedIndex];
      if (focused) {
        focused.classList.add('kbd-focused');
        focused.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        this.announceNavigation();
      }
    }

    openFocused() {
      const item = this.items[this.focusedIndex];
      if (!item) return;
      const link = item.querySelector('a');
      if (link) window.open(link.href, '_blank', 'noopener,noreferrer');
    }

    showHelp() {
      document.getElementById('keyboard-help-modal')?.classList.add('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
    }

    toggleTheme() {
      if (typeof window.toggleTheme === 'function') {
        window.toggleTheme();
      }
    }

    hideHelp() {
      document.getElementById('keyboard-help-modal')?.classList.remove('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.remove('visible');
    }

    handleEscape() {
      const helpModal = document.getElementById('keyboard-help-modal');
      if (helpModal?.classList.contains('visible')) {
        this.hideHelp();
        return;
      }
      if (document.activeElement === this.searchInput) {
        this.searchInput?.blur();
        return;
      }
      this.items.forEach(el => el.classList.remove('kbd-focused'));
      this.focusedIndex = -1;
    }

    announceNavigation() {
      const item = this.items[this.focusedIndex];
      const liveRegion = document.getElementById('kbd-live-region');
      if (liveRegion && item) {
        const title = item.querySelector('h2, .release-title')?.textContent?.trim() || 'Post';
        liveRegion.textContent = `Focused: ${title}`;
      }
    }

    refresh() {
      this.items = Array.from(document.querySelectorAll(this.itemSelector));
    }
  }

  let navigator = null;
  document.addEventListener('DOMContentLoaded', () => {
    navigator = new KeyboardNavigator('.release-card:not([aria-hidden="true"] .release-card)', '#search-input, .search-bar input');

    const observer = new MutationObserver(() => navigator?.refresh());
    const releaseList = document.getElementById('release-list');
    if (releaseList) observer.observe(releaseList, { childList: true });
    const infiniteScrollContainer = document.querySelector('.infinite-scroll-container');
    if (infiniteScrollContainer) observer.observe(infiniteScrollContainer, { childList: true, subtree: true });
  });
</script>
