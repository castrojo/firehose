{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "Astro docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": true
    },
    "cncf-landscape": {
      "type": "local",
      "command": [
        "podman", "run", "-i", "--rm",
        "ghcr.io/cncf/landscape-mcp-server:main",
        "--data-url", "https://landscape.cncf.io/data/full.json"
      ],
      "enabled": true
    }
  }
}
